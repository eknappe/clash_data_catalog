<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CLaSH Dataset Catalog</title>

  {# Google fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
  {# map inset basemaps #}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  {# style.css is copied into site/ alongside index.html by build.py #}
  <link rel="stylesheet" href="style.css" />
</head>
<body>

{# ------------------------------------------------
  header with project title and build timestamp #}

<header>
  <div class="header-inner">
    <a href="https://www.geoclash.org" target="_blank" rel="noopener" class="logo">
      <img src="clash_logo.png" class="logo-mark" alt="CLaSH logo" />
      <div class="logo-text">
        CLaSH Metadata Catalog
        <span>Network-wide · Internal Use Only</span>
      </div>
    </a>
    <div class="build-time">Data last updated at {{ built_at }}</div>
  </div>
</header>

{# ------------------------------------------------
   stats bar - summary stats at the top and then observatory loop to generate one box per observatory #}

<div class="stats-bar">
  <div class="stats-inner">

    <div class="stat">
      <div class="stat-value">{{ total }}</div>
      <div class="stat-label">Datasets</div>
    </div>

    <div class="stat">
      <div class="stat-value">{{ "%.0f"|format(total_gb) }} GB</div>
      <div class="stat-label">Total Size</div>
    </div>

    {% for obs in observatories %}
    <div class="stat">
      {# CSS variable name derived from observatory name, e.g. "SoCal" → "--socal" #}
      <div class="stat-value" style="color:var(--{{ obs | lower | replace(' ', '-') }})">
        {{ obs_counts[obs] }}
      </div>
      <div class="stat-label">{{ obs }}</div>
    </div>
    {% endfor %}

  </div>
</div>

{# ------------------------------------------------
   main page - two col layout
   left (<aside>) : filter sidebar
   right (<main>) : search, result count, dataset cards #}

<div class="page">

  {# ── left sidebar: filter controls
     each sidebar-section is one filter group. buttons use
     onclick="toggleFilter(...)" handled by javascript below.
     All actual filtering runs client-side in the browser — no page reload. #}
  <aside class="sidebar">

    {# free-text search: filters cards as the user types #}
    <div class="search-wrap">
      <input class="search-input"
             type="text"
             id="searchInput"
             placeholder="Search datasets…"
             oninput="applyFilters()" />
    </div>

    {# observatory filter #}
    <div class="sidebar-section">
      <div class="sidebar-title">Observatory</div>
      <button class="filter-btn active"
              onclick="toggleFilter(this,'obs','all')"
              data-group="obs" data-val="all">All observatories</button>
      {% for obs in observatories %}
      <button class="filter-btn"
              onclick="toggleFilter(this,'obs','{{ obs }}')"
              data-group="obs" data-val="{{ obs }}">
        <span class="dot dot-{{ obs | lower | replace(' ', '') }}"></span>{{ obs }}
      </button>
      {% endfor %}
    </div>

    {# collection date range picker 
       datasets with no collection_start are always as default.
       The "Clear dates" button only appears when a date is set (toggled by JS). #}
    <div class="sidebar-section">
      <div class="sidebar-title">Collection Date</div>
      <div class="date-range">
        <div class="date-range-row">
          <span class="date-range-label">From</span>
          <input class="date-input"
                 type="date"
                 id="dateFrom"
                 onchange="applyFilters()" />
        </div>
        <div class="date-range-row">
          <span class="date-range-label">To</span>
          <input class="date-input"
                 type="date"
                 id="dateTo"
                 onchange="applyFilters()" />
        </div>
        <button class="date-clear-btn"
                id="dateClearBtn"
                onclick="clearDateFilter()">✕ Clear dates</button>
      </div>
    </div>

    {# data type filter — values from DATA_TYPES list in build.py #}
    <div class="sidebar-section">
      <div class="sidebar-title">Data Type</div>
      <button class="filter-btn active"
              onclick="toggleFilter(this,'type','all')"
              data-group="type" data-val="all">All types</button>
      {% for t in data_types %}
      <button class="filter-btn"
              onclick="toggleFilter(this,'type','{{ t }}')"
              data-group="type" data-val="{{ t }}">{{ t }}</button>
      {% endfor %}
    </div>

    {# data level filter #}
    <div class="sidebar-section">
      <div class="sidebar-title">Data Level</div>
      <button class="filter-btn active"
              onclick="toggleFilter(this,'level','all')"
              data-group="level" data-val="all">All levels</button>
      {% for level in data_levels %}
      {# Split "L2a: Quality controlled data" into code and label parts #}
      {% set parts = level.split(': ', 1) %}
      <button class="filter-btn"
              onclick="toggleFilter(this,'level','{{ level }}')"
              data-group="level" data-val="{{ level }}">
        <span class="level-code">{{ parts[0] }}</span>{{ parts[1] if parts|length > 1 else '' }}
      </button>
      {% endfor %}
    </div>

    {# collection status filter #}
    <div class="sidebar-section">
      <div class="sidebar-title">Collection Status</div>
      <button class="filter-btn active"
              onclick="toggleFilter(this,'cstatus','all')"
              data-group="cstatus" data-val="all">All statuses</button>
      {% for s in collection_statuses %}
      <button class="filter-btn"
              onclick="toggleFilter(this,'cstatus','{{ s }}')"
              data-group="cstatus" data-val="{{ s }}">{{ s }}</button>
      {% endfor %}
    </div>


  </aside>

  {# --- RIGHT MAIN AREA: dataset cards ------------------------------
     cards are NOT written here — they are built by the
     javascript renderCard() function and injected into #datasetList.
     this allows instant filtering/sorting without reloading the page. #}
  <main>

    {# row above cards: result count (left) and sort dropdown (right) #}
    <div class="results-header">
      <div class="results-count" id="resultsCount">Showing {{ total }} datasets</div>
      <select class="sort-select" onchange="applyFilters()" id="sortSelect">
        <option value="date_desc">Newest first</option>
        <option value="date_asc">Oldest first</option>
        <option value="name_asc">Name A→Z</option>
        <option value="size_desc">Largest first</option>
      </select>
    </div>

    {# cards injected here by javascript #}
    <div id="datasetList"></div>

    {# shown only when no datasets match active filters #}
    <div class="empty-state" id="emptyState" style="display:none">
      <p>No datasets match the current filters.</p>
    </div>

  </main>
</div>


{# -------------------------------------------------
   JAVASCRIPT
   rangeuns entirely in the user's browser — no server needed.

   the full dataset list is embedded as JSON ({{ datasets_json }}) so the
   browser has everything it needs to filter, sort, and render cards without
   any further network requests

   Functions:
     toggleFilter(btn, group, val) — called on sidebar button click;
       updates active filter state and re-renders cards.
     applyFilters()  — reads all filters + search text, filters the DATASETS
       array, sorts, and renders the card list.
     renderCard(d)   — returns the HTML string for one dataset card.
     toggleCard(id)  — shows/hides the detail panel when a card is clicked.

   Helper functions:
     obsClass(obs)      — maps observatory name → CSS class suffix
     cstatusClass(s)    — maps collection status → CSS class name
     renderObsTags(d)   — builds observatory tag HTML for a dataset
     esc(s)             — HTML-escapes a string (security: prevents XSS)
     row(key, val)      — builds one key-value detail row, or '' if empty
------------------------------------------------------------------------ #}

<script>
// full dataset array embedded at build time by build.py.
// each element is an object with all fields from datasets.yaml.
const DATASETS = {{ datasets_json }};

// active filter state — one entry per filter group.
// 'all' means no filter applied for that group.
// date range is handled separately via the dateFrom/dateTo input elements
// rather than the filters object, since it's a range not a discrete value.
const filters = {
  obs:     'all',
  type:    'all',
  level:   'all',
  cstatus: 'all',
};

// called when a sidebar filter button is clicked.
// updates the filter state, highlights the active button, re-renders cards.
function toggleFilter(btn, group, val) {
  filters[group] = val;
  document.querySelectorAll(`[data-group="${group}"]`)
          .forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

// maps an observatory name to the CSS class suffix used for colouring.
// e.g. "Puerto Rico" → "puertorico"
function obsClass(obs) {
  const map = {
    'Alaska':      'alaska',
    'Appalachia':  'appalachia',
    'SoCal':       'socal',
    'Puerto Rico': 'puertorico',
    'Other':       'other',
    'Network wide': 'networkwide',
  };
  return map[obs] || 'network';
}

// maps a collection status string to the CSS class name for its badge colour.
function cstatusClass(s) {
  if (!s) return 'cstatus-complete';
  const sl = s.toLowerCase();
  if (sl === 'active')  return 'cstatus-active';
  if (sl === 'published') return 'cstatus-published';
  return 'cstatus-complete';
}

// builds the observatory tag pill(s) for a card.
// if >2 observatories, shows a compact "Multi-observatory (N)" summary.
function renderObsTags(d) {
  const obs = d.observatories || [];
  if (obs.length === 0) return '<span class="tag tag-obs-networkwide">Network-wide</span>';
  if (obs.length > 2)   return `<span class="tag tag-obs-networkwide">Multi-observatory (${obs.length})</span>`;
  return obs.map(o => `<span class="tag tag-obs-${obsClass(o)}">${o === 'Other' ? 'Other locations' : o}</span>`).join('');
}

// html-escapes a value before inserting it into the page.
// prevents xss if any yaml field contains special characters.
function esc(s) {
  return s
    ? String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
    : '';
}

// returns an HTML detail row string if the value is non-empty, else ''
// rows with no value are simply omitted from the detail panel.
function row(key, val) {
  return (val || val === 0)
    ? `<div class="detail-row">
         <span class="detail-key">${key}</span>
         <span class="detail-val">${esc(String(val))}</span>
       </div>`
    : '';
}

// converts a dataset's collection_start field to a comparable date string
// (YYYY-MM-DD). returns null if the field is absent 
// used by both the date range filter and the free-text search.
function getDateStr(d) {
  if (!d.collection_start) return null;
  // PyYAML may parse YYYY-MM-DD values as JS-style date strings;
  // take the first 10 characters to normalise to YYYY-MM-DD.
  return String(d.collection_start).slice(0, 10);
}

// add in the spatial data, e.g. lat/lon
function renderSpatial(d) {
  if (!d.spatial) return '';
  const s = d.spatial;
  let content = '';

  if (s.type === 'points') {
    content = (s.locations || []).map(p =>
      `<a href="https://maps.google.com/?q=${p.lat},${p.lon}"
          target="_blank" rel="noopener" style="color:var(--accent2)">
         ${p.name ? esc(p.name) : (p.lat + '°, ' + p.lon + '°')}
       </a>`
    ).join('<br>');

  } else if (s.type === 'bboxes') {
    content = (s.boxes || []).map(b =>
      `${b.name ? b.name + ': ' : ''}N ${b.north}° S ${b.south}° E ${b.east}° W ${b.west}°`
    ).join('<br>');
  }

  return `<div class="detail-row">
            <span class="detail-key">Spatial Coverage</span>
            <span class="detail-val">${content}</span>
          </div>`;
}

// clears both date inputs and hides the "clear dates" button,
// then re-renders the card list
function clearDateFilter() {
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value   = '';
  document.getElementById('dateClearBtn').classList.remove('visible');
  applyFilters();
}

// shows or hides the "Clear dates" button depending on whether
// either date input currently has a value
function updateClearBtn() {
  const from = document.getElementById('dateFrom').value;
  const to   = document.getElementById('dateTo').value;
  document.getElementById('dateClearBtn').classList.toggle('visible', !!(from || to));
}

// builds the complete html for one dataset card:
//   - summary header (always visible): ID, name, description, tags, badges
//   - detail panel (hidden until clicked): full metadata grid + notes
function renderCard(d) {
  const obsTags    = renderObsTags(d);
  const typeTag    = d.data_type
    ? `<span class="tag tag-type">${esc(d.data_type)}</span>` : '';

  // pplit "L2a: Quality controlled data" into code and label
  const levelCode  = d.data_level ? d.data_level.split(':')[0] : '';
  const levelLabel = d.data_level ? (d.data_level.split(': ')[1] || d.data_level) : '';

  // flatten arrays to comma-separated strings for display
  const personnel = (d.personnel || []).join(', ');
  const params    = (d.parameters_measured || []).join(', ');

  // Date range — filter(Boolean) drops null/empty end dates
  const dates   = [d.collection_start, d.collection_end].filter(Boolean).join(' → ') || '—';
  const obsList = (d.observatories || []).join(', ') || 'Network-wide';

  // Map inset
  const mapDiv = d.spatial
    ? `<div id="map-${d.id}" style="height:220px; margin-top:1rem; border-radius:4px; border:1px solid var(--border); background:var(--bg);"></div>`
    : '';

  // notes callout — only rendered if the field is non-empty
  const notes   = d.notes
    ? `<div class="detail-notes">${esc(d.notes)}</div>` : '';

  return `
<div class="dataset-card" id="card-${d.id}" onclick="toggleCard('${d.id}')">
  <div class="card-header">
    <div>
      <div class="card-id">${esc(d.id)}</div>
      <div class="card-name">${esc(d.name)}</div>
      <div class="card-desc">${esc(d.description)}</div>
      <div class="card-meta">${obsTags}${typeTag}</div>
    </div>
    <div class="status-badges">
      ${d.data_level
        ? `<span class="level-badge">${esc(levelCode)}: ${esc(levelLabel)}</span>`
        : ''}
      ${d.collection_status
        ? `<span class="cstatus-badge ${cstatusClass(d.collection_status)}">${esc(d.collection_status)}</span>`
        : ''}
      <span class="expand-icon">⌄</span>
    </div>
  </div>

  <!-- detail panel: hidden by default, .open makes it visible -->
  <div class="card-detail" id="detail-${d.id}">
    <div class="detail-grid">

      <div>
        <div class="detail-section-title">Collection</div>
        ${row('PI',                d.pi)}
        ${row('Institution',       d.institution)}
        ${row('Personnel',         personnel)}
        ${row('Observatory',       obsList)}
        ${row('Field Site',        d.field_site)}
        ${renderSpatial(d)}
        ${row('Dates',             dates)}
      </div>

      <div>
        <div class="detail-section-title">Data</div>
        ${row('Data Type',         d.data_type)}
        ${row('Data Level',        d.data_level)}
        ${row('Collection Status', d.collection_status)}
        ${row('Instrument',        d.instrument)}
        ${row('Parameters',        params)}
        ${row('Temporal Res.',     d.temporal_resolution)}
        ${row('Spatial Res.',      d.spatial_resolution)}
        ${row('Format',            d.format)}
        ${row('Size',              d.size_gb != null ? d.size_gb + ' GB' : '')}
      </div>

      <div>
        <div class="detail-section-title">Access</div>
        ${row('Location',          d.data_location)}
        ${row('Access Notes',      d.access_notes)}
        ${row('DOI',               d.doi || 'Not yet assigned')}
        ${row('Date Added',        d.date_added)}
      </div>

    </div>
    ${mapDiv}
    ${notes}
  </div>
</div>`;
}  

// toggles expanded/collapsed state of a card when clicked.
// adds/removes CSS classes that show the detail panel and rotate the arrow.
function toggleCard(id) {
  const card   = document.getElementById('card-'   + id);
  const detail = document.getElementById('detail-' + id);
  const isOpen = detail.classList.contains('open');
  detail.classList.toggle('open',   !isOpen);
  card.classList.toggle('expanded', !isOpen);

  if (!isOpen) {
  const dataset = DATASETS.find(d => d.id === id);
  if (dataset && dataset.spatial) {
    setTimeout(() => initMap(id, dataset.spatial), 50);
  }
  }
}


// map fuction
function initMap(id, spatial) {
  const el = document.getElementById('map-' + id);
  if (!el || el._leaflet_id) return;

  const map = L.map('map-' + id, {
    zoomControl: true,
    scrollWheelZoom: false,
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO',
    maxZoom: 19,
  }).addTo(map);

  if (spatial.type === 'points') {
    const latlngs = spatial.locations.map(p => [p.lat, p.lon]);
    latlngs.forEach((ll, i) => {
      const m = L.circleMarker(ll, {
        radius: 6, fillColor: '#fcb900', color: '#000',
        weight: 1, opacity: 1, fillOpacity: 0.9,
      }).addTo(map);
      if (spatial.locations[i].name) m.bindTooltip(spatial.locations[i].name);
    });
    map.fitBounds(L.latLngBounds(latlngs), { padding: [30, 30] });

  } else if (spatial.type === 'bboxes') {
    const allBounds = [];
    spatial.boxes.forEach(b => {
      const bounds = [[b.south, b.west], [b.north, b.east]];
      allBounds.push(...bounds);
      const rect = L.rectangle(bounds, {
        color: '#fcb900', weight: 2, fillOpacity: 0.1,
      }).addTo(map);
      if (b.name) rect.bindTooltip(b.name);
    });
    map.fitBounds(L.latLngBounds(allBounds), { padding: [30, 30] });
  }
}

// main filter + sort + render function.
// called on every user interaction: button click, keystroke, sort change.
function applyFilters() {
  const q       = document.getElementById('searchInput').value.toLowerCase();
  const sort    = document.getElementById('sortSelect').value;
  const dateFrom = document.getElementById('dateFrom').value; // 'YYYY-MM-DD' or ''
  const dateTo   = document.getElementById('dateTo').value;   // 'YYYY-MM-DD' or ''

  // show/hide the "Clear dates" button
  updateClearBtn();

  let results = DATASETS.filter(d => {

    // observatory filter — dataset must include the selected observatory
    if (filters.obs !== 'all' && !(d.observatories || []).includes(filters.obs))
      return false;

    // date range filter — include dataset if:
    //   (a) it has no collection_start (don't silently exclude undated data), OR
    //   (b) its start date falls within the selected from/to range.
    // ISO date strings (YYYY-MM-DD) sort lexicographically so < and > work correctly.
    const startStr = getDateStr(d);
    const endStr   = d.collection_end ? String(d.collection_end).slice(0, 10) : null;
    if (startStr) {
      // dataset must start before (or on) the selected "To" date
      if (dateTo   && startStr > dateTo)   return false;
      // dataset must end after (or on) the selected "From" date,
      // OR have no end date (ongoing — open-ended into the future)
      if (dateFrom && endStr && endStr < dateFrom) return false;
      if (dateFrom && !endStr && startStr > dateFrom) return false;
    }

    // exact-match filters for controlled-vocabulary fields
    if (filters.type    !== 'all' && d.data_type        !== filters.type)    return false;
    if (filters.level   !== 'all' && d.data_level        !== filters.level)   return false;
    if (filters.cstatus !== 'all' && d.collection_status !== filters.cstatus) return false;

    // free-text search — checks a concatenation of all searchable fields
    if (q) {
      const blob = [
        d.name, d.description, d.pi, d.institution, d.field_site,
        d.data_type, d.data_level, d.collection_status, d.instrument,
        getDateStr(d),
        ...(d.observatories       || []),
        ...(d.parameters_measured || []),
      ].join(' ').toLowerCase();
      if (!blob.includes(q)) return false;
    }

    return true;
  });

  // sort the filtered results
  results.sort((a, b) => {
    if (sort === 'date_desc') return (b.date_added || '').localeCompare(a.date_added || '');
    if (sort === 'date_asc')  return (a.date_added || '').localeCompare(b.date_added || '');
    if (sort === 'name_asc')  return (a.name       || '').localeCompare(b.name       || '');
    if (sort === 'size_desc') return (b.size_gb    || 0) - (a.size_gb || 0);
    return 0;
  });

  const list  = document.getElementById('datasetList');
  const empty = document.getElementById('emptyState');
  const count = document.getElementById('resultsCount');

  if (results.length === 0) {
    list.innerHTML      = '';
    empty.style.display = 'block';
    count.textContent   = 'No datasets found';
  } else {
    // build all card HTML strings and inject in one operation
    list.innerHTML      = results.map(renderCard).join('');
    empty.style.display = 'none';
    count.textContent   = `Showing ${results.length} of ${DATASETS.length} dataset${DATASETS.length !== 1 ? 's' : ''}`;
  }
}

// initial render on page load — no filters active, all datasets shown
applyFilters();

</script>

</body>
</html>